eters":[2,0,1,0,400,272,100,100,255,0,60,true,3]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Ты заходишь в ванную и смотришь на себя в маске. Она такая "]},{"code":401,"indent":0,"parameters":["холодная. Она напоминает тебе \\C[14]что-то.\\C[0]"]},{"code":232,"indent":0,"parameters":[2,0,1,0,400,320,100,100,255,0,60,false,3]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Когда тебе было восемь, в школе, ты однажды сказал учителю "]},{"code":401,"indent":0,"parameters":["что-то бессвязное."]},{"code":232,"indent":0,"parameters":[2,0,1,0,416,296,100,100,0,0,60,false,3]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Ты обедал и сказал ей: \\C[3]\"маска очень холодная\".\\C[0] "]},{"code":401,"indent":0,"parameters":["Весь класс рассмеялся."]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Даже сейчас ты снова говоришь ей это. Или это в первый раз? "]},{"code":401,"indent":0,"parameters":["И — конечно же — \\C[5]они все смеются.\\C[0]"]},{"code":231,"indent":0,"parameters":[2,"endcut/MS3",1,0,432,544,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,1,0,384,256,100,100,255,0,60,false,2]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Ты берёшь с собой половину бутерброда. Ты помнишь, как мама "]},{"code":401,"indent":0,"parameters":["резала их треугольниками."]},{"code":232,"indent":0,"parameters":[2,0,1,0,416,400,100,100,0,0,60,false,2]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Она и сейчас режет их на треугольники. Но у тебя уже есть кусок. "]},{"code":401,"indent":0,"parameters":["Это тот самый кусок, который она режет сейчас. Ты говоришь ей не "]},{"code":401,"indent":0,"parameters":["утруждаться, потому что \\C[14]она уже это сделала.\\C[0]"]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["В этот раз слова застревают у тебя в горле. Ты просто зависаешь "]},{"code":401,"indent":0,"parameters":["позади неё, твои теперь бесчисленные руки безвольно свисают. Она "]},{"code":401,"indent":0,"parameters":["оборачивается и \\C[5]кричит,\\C[0] и ты исчезаешь. Наверное, "]},{"code":401,"indent":0,"parameters":["ты её напугал."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Может, тебе нужно спрятаться, чтобы так сильно не пугать людей. "]},{"code":401,"indent":0,"parameters":["Ты ищешь какое-нибудь одеяло."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Ты вспоминаешь то \\C[14]большое чёрное одеяло,\\C[0] которое было "]},{"code":401,"indent":0,"parameters":["у тебя в подростковом возрасте и однажды исчезло. Оно было очень "]},{"code":401,"indent":0,"parameters":["удобным. Ты задумываешься, что с ним стало."]},{"code":231,"indent":0,"parameters":[2,"endcut/MS4",1,0,408,520,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,1,0,400,232,100,100,255,0,60,false,2]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["О, вот оно.. \\C[3]Какое везение!\\C[0]"]},{"code":232,"indent":0,"parameters":[2,0,1,0,408,368,100,100,255,0,60,false,3]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Наверное, ты его и не терял — ты просто одолжил его у самого себя... "]},{"code":401,"indent":0,"parameters":["Надвигается ужасная головная боль."]},{"code":232,"indent":0,"parameters":[2,0,1,0,408,496,100,100,0,0,60,false,3]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Ты хочешь \\C[14]извиниться перед соседом по комнате.\\.\\C[0] Ты помнишь, "]},{"code":401,"indent":0,"parameters":["как обвинял его в том, что он его украл.\\. А, вот он — разговаривает "]},{"code