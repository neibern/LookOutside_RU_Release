да им были."]},{"code":250,"indent":0,"parameters":[{"name":"DeathTree3","volume":25,"pitch":50,"pan":-60}]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Сначала тебя охватывает ужас от того, что ты совершаешь, и ты "]},{"code":401,"indent":0,"parameters":["пытаешься это остановить. Но ты \\C[5]не можешь.\\C[0] Твоя собственная "]},{"code":401,"indent":0,"parameters":["масса на самом деле тебе не подвластна. Ты — дирижёр \\C[14]мятежного, "]},{"code":401,"indent":0,"parameters":["непокорного оркестра."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Ты чувствуешь, как твоё страшное знание заражает всё больше."]},{"code":231,"indent":0,"parameters":[1,"endcut/Un2",1,0,408,312,100,100,0,0]},{"code":232,"indent":0,"parameters":[1,0,1,0,408,312,100,100,255,0,120,false,2]},{"code":250,"indent":0,"parameters":[{"name":"DeathTree3","volume":25,"pitch":50,"pan":-60}]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Мужчина вскрикивает, прося о помощи, и погружается в диван. Ты "]},{"code":401,"indent":0,"parameters":["обнимаешь его руками-подлокотниками, прижимаешь к своему "]},{"code":401,"indent":0,"parameters":["стёганному торсу."]},{"code":232,"indent":0,"parameters":[1,0,1,0,408,312,100,100,0,0,120,false,1]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["\\C[3]Всё будет хорошо,\\C[0] — говоришь ты ему.\\.\\. Ты уже забыл "]},{"code":401,"indent":0,"parameters":["его имя.\\.\\. \\C[14]Как и он сам."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Семья из четырёх человек обнимается в последний раз, сливаясь "]},{"code":401,"indent":0,"parameters":["друг с другом. Ты чувствуешь слёзы на их щеках. Ты чувствуешь их "]},{"code":401,"indent":0,"parameters":["\\C[5]любовь и страх.\\C[0] А затем — \\C[14]ничего.\\C[0] Всё, "]},{"code":401,"indent":0,"parameters":["что