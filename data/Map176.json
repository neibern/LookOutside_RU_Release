с.\\.\\.\\.\\. \\C[10]Оно на вкус как...\\.\\.\\.\\.\\^"]},{"code":242,"indent":0,"parameters":[1]},{"code":246,"indent":0,"parameters":[1]},{"code":251,"indent":0,"parameters":[]},{"code":230,"indent":0,"parameters":[240]},{"code":241,"indent":0,"parameters":[{"name":"DistantScream","volume":15,"pitch":60,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["\\..\\..\\..ты ощущаешь обновлённое, непреодолимое желание "]},{"code":401,"indent":0,"parameters":["что-нибудь погрызть, но грызть больше нечего."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Раньше было так много всего, что можно было погрызть. "]},{"code":401,"indent":0,"parameters":["А теперь — ничего."]},{"code":231,"indent":0,"parameters":[1,"endcut/X5a",1,0,408,312,100,100,0,0]},{"code":231,"indent":0,"parameters":[2,"endcut/X5b",1,0,512,416,100,100,255,0]},{"code":231,"indent":0,"parameters":[3,"endcut/X5c",1,0,512,416,100,100,0,0]},{"code":232,"indent":0,"parameters":[1,0,1,0,408,312,100,100,255,0,120,false,0]},{"code":232,"indent":0,"parameters":[2,0,1,0,408,312,100,100,255,0,900,false,2]},{"code":232,"indent":0,"parameters":[3,0,1,0,408,312,100,100,0,0,900,false,2]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Была Луна, но, вопреки смутно помнящимся сказаниям, она "]},{"code":401,"indent":0,"parameters":["оказалась всего лишь камнем. И ты отпускаешь её.\\.\\. пока."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Осталась лишь холодная пустота космоса."]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Раньше было много криков — долгое время. "]},{"code":401,"indent":0,"parameters":["Но теперь всё кончено."]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["Тебе