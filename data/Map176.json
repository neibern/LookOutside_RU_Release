оловы."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["Бежать некуда. Бесконечно разрастающаяся крысиная плоть "]},{"code":401,"indent":0,"parameters":["накатывает на тебя — вокруг тебя."]},{"code":230,"indent":0,"parameters":[30]},{"code":232,"indent":0,"parameters":[1,0,1,0,408,312,100,100,0,0,120,false,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["Осколок разума твоих друзей-астрономов сдерживал рост монстра, "]},{"code":401,"indent":0,"parameters":["даруя тебе призрачный шанс..."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["...но теперь его нет. В твари не осталось ни мысли, ни души. "]},{"code":401,"indent":0,"parameters":["Она лишь растёт и пожирает."]},{"code":230,"indent":0,"parameters":[30]},{"code":231,"indent":0,"parameters":[2,"endcut/X2",1,0,408,312,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,1,0,408,312,100,100,255,0,120,false,0]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["Даже близлежащие здания покрыты плотью бога. Он разрастается "]},{"code":401,"indent":0,"parameters":["экспоненциально."]},{"code":230,"indent":0,"parameters":[30]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["Молящие всхлипы и искажённые ужасом крики внизу обрываются "]},{"code":401,"indent":0,"parameters":["под ударами мечущихся конечностей и щёлканьем челюстей."]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["Вдали поднимается огромная башня из крысиных лап. Она, должно "]},{"code":401,"indent":0,"parameters":["быть, в сотне метров от тебя. Другая вздымается из кровавого "]},{"code":401,"indent":0,"parameters":["месива позади тебя."]},{"code":232,"indent":0,"parameters":[2,0,1,0,408,312,100,100,0,0,120,false,0]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{